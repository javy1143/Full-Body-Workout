          <button className="tb" onClick={() => setDash(true)} style={{
            display: "flex", alignItems: "center", gap: 10, padding: "0 18px",
            borderLeft: `1px solid ${C.line}`, color: C.dimHi,
          }}
            onMouseOver={e => e.currentTarget.style.color = C.cyan}
            onMouseOut={e => e.currentTarget.style.color = C.dimHi}
          >
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" strokeWidth="1.5">
              <rect x="1" y="9" width="4" height="6" rx="0.5"/><rect x="6" y="5" width="4" height="10" rx="0.5"/><rect x="11" y="1" width="4" height="14" rx="0.5"/>
            </svg>
            <div>
              <div style={{ fontFamily: "'Barlow Condensed',sans-serif", fontSize: 13, letterSpacing: 2 }}>DASHBOARD</div>
              <div style={{ fontFamily: "'DM Sans',sans-serif", fontSize: 8, letterSpacing: 1, opacity: 0.6 }}>{totalLogged > 0 ? `${totalLogged} ENTRIES` : "NO DATA YET"}</div>
            </div>
          </button>
        </div>
      </div>

      <div style={{ maxWidth: 700, margin: "0 auto", padding: "0 16px" }}>

        {/* ── TAB SWITCHER ── */}
        <div style={{ display: "flex", borderBottom: `1px solid ${C.line}`, marginBottom: 0 }}>
          {["A", "B"].map(key => {
            const active = tab === key;
            return (
              <button key={key} className="tb" onClick={() => { setTab(key); setOpen(null); }} style={{
                flex: 1, padding: "20px 0", position: "relative",
                borderBottom: active ? `2px solid ${C.cyan}` : "2px solid transparent",
              }}>
                <div style={{ fontFamily: "'Barlow Condensed',sans-serif", fontSize: 22, letterSpacing: 3, color: active ? C.white : C.dim, transition: "color 0.2s" }}>
                  {workouts[key].label}
                </div>
                <div style={{ fontFamily: "'DM Sans',sans-serif", fontSize: 10, color: active ? C.cyanDim : C.dim, letterSpacing: 1, marginTop: 2, transition: "color 0.2s" }}>
                  {workouts[key].tag}
                </div>
                {active && <div style={{ position: "absolute", bottom: -1, left: "50%", transform: "translateX(-50%)", width: 6, height: 6, background: C.cyan, borderRadius: "50%", boxShadow: `0 0 8px ${C.cyan}` }} />}
              </button>
            );
          })}
        </div>

        {/* ── EXERCISE TABLE ── */}
        <div style={{ marginBottom: 32 }}>
          {/* Header */}
          <div style={{ display: "grid", gridTemplateColumns: "1fr 46px 74px 50px 84px 20px", padding: "10px 12px", borderBottom: `1px solid ${C.line}` }}>
            {["Exercise", "Sets", "Reps", "Rest", "1RM", ""].map((h, i) => (
              <div key={i} style={{ fontFamily: "'DM Sans',sans-serif", fontSize: 8, color: C.dim, letterSpacing: 2, textTransform: "uppercase", textAlign: i > 0 ? "center" : "left" }}>{h}</div>
            ))}
          </div>

          {workout.exercises.map((ex, i) => {
            const exLogs = logs[ex.name] || [];
            const best1rm = exLogs.length ? Math.max(...exLogs.map(l => l.e1rm)) : null;
            const lastLog = exLogs.length ? exLogs[exLogs.length - 1] : null;
            const suggested = suggestNext(exLogs, ex.reps);
            const isOpen = open === i;

            return (
              <div key={ex.name}>
                <div className="ex-row" onClick={() => setOpen(isOpen ? null : i)} style={{
                  display: "grid", gridTemplateColumns: "1fr 46px 74px 50px 84px 20px",
                  padding: "13px 12px", alignItems: "center",
                  background: isOpen ? C.cyanFog : "transparent",
                }}>
                  <div style={{ display: "flex", alignItems: "center", gap: 10, minWidth: 0 }}>
                    <div style={{ width: 3, height: 28, background: muscleColors[ex.muscle] || C.cyan, borderRadius: 2, flexShrink: 0, boxShadow: `0 0 6px ${(muscleColors[ex.muscle]||C.cyan)}66` }} />
                    <div style={{ minWidth: 0 }}>
                      <div style={{ fontFamily: "'Barlow Condensed',sans-serif", fontSize: 16, color: C.white, letterSpacing: 0.3, lineHeight: 1.2 }}>{ex.name}</div>
                      <div style={{ fontFamily: "'DM Sans',sans-serif", fontSize: 9, color: C.dim, letterSpacing: 1, textTransform: "uppercase", marginTop: 1 }}>{ex.muscle}</div>
                    </div>
                  </div>
                  <div style={{ textAlign: "center", fontFamily: "'Barlow Condensed',sans-serif", fontSize: 22, color: C.cyan, filter: `drop-shadow(0 0 4px ${C.cyanGlow})` }}>{ex.sets}</div>
                  <div style={{ textAlign: "center", fontFamily: "'DM Sans',sans-serif", fontSize: 12, color: C.dimHi }}>{ex.reps}</div>
                  <div style={{ textAlign: "center", fontFamily: "'DM Sans',sans-serif", fontSize: 11, color: C.dim }}>{ex.rest}</div>
                  <div style={{ textAlign: "center", fontFamily: "'Barlow Condensed',sans-serif", fontSize: 18, color: best1rm ? C.cyan : C.line, filter: best1rm ? `drop-shadow(0 0 4px ${C.cyanGlow})` : "none" }}>
                    {best1rm || "—"}
                  </div>
                  <div style={{ textAlign: "center", fontFamily: "monospace", fontSize: 13, color: isOpen ? C.cyan : C.dim, transition: "all 0.2s", transform: isOpen ? "rotate(45deg)" : "none", display: "inline-block" }}>+</div>
                </div>

                {isOpen && (
                  <div style={{ padding: "14px 12px 16px 28px", background: `linear-gradient(90deg, ${C.cyanFog}, transparent)`, borderBottom: `1px solid ${C.line}` }}>
                    {/* Tip */}
                    <div style={{ fontFamily: "'DM Sans',sans-serif", fontSize: 12, color: C.dimHi, lineHeight: 1.7, marginBottom: 14, fontStyle: "italic" }}>
                      <span style={{ color: C.cyanDim, marginRight: 6 }}>◆</span>{ex.tip}
                    </div>

                    {/* Mini stats */}
                    <div style={{ display: "flex", gap: 8, marginBottom: 12, flexWrap: "wrap" }}>
                      {lastLog && (
                        <div style={{ background: C.bg2, border: `1px solid ${C.line}`, borderRadius: 2, padding: "8px 12px", flex: "1 1 88px" }}>
                          <div style={{ fontFamily: "'DM Sans',sans-serif", fontSize: 8, color: C.dim, letterSpacing: 2, textTransform: "uppercase", marginBottom: 3 }}>Last Set</div>
                          <div style={{ fontFamily: "'Barlow Condensed',sans-serif", fontSize: 18, color: C.white }}>{lastLog.weight} <span style={{ fontSize: 10, color: C.dim }}>lbs</span> × {lastLog.reps}</div>
                          <div style={{ fontFamily: "'DM Sans',sans-serif", fontSize: 9, color: C.dim }}>{lastLog.date}</div>
                        </div>
                      )}
                      {suggested && (
                        <div style={{ background: C.cyanFog, border: `1px solid ${C.line}`, borderLeft: `2px solid ${C.cyan}`, borderRadius: 2, padding: "8px 12px", flex: "1 1 88px" }}>
                          <div style={{ fontFamily: "'DM Sans',sans-serif", fontSize: 8, color: C.cyan, letterSpacing: 2, textTransform: "uppercase", marginBottom: 3 }}>Next Session</div>
                          <div style={{ fontFamily: "'Barlow Condensed',sans-serif", fontSize: 18, color: C.white }}>{suggested} <span style={{ fontSize: 10, color: C.dim }}>lbs</span></div>
                          <div style={{ fontFamily: "'DM Sans',sans-serif", fontSize: 9, color: C.dim }}>target weight</div>
                        </div>
                      )}
                      {best1rm && (
                        <div style={{ background: C.bg2, border: `1px solid ${C.line}`, borderRadius: 2, padding: "8px 12px", flex: "1 1 88px" }}>
                          <div style={{ fontFamily: "'DM Sans',sans-serif", fontSize: 8, color: C.dim, letterSpacing: 2, textTransform: "uppercase", marginBottom: 3 }}>Best 1RM</div>
                          <div style={{ fontFamily: "'Barlow Condensed',sans-serif", fontSize: 18, color: C.cyan, filter: `drop-shadow(0 0 4px ${C.cyanGlow})` }}>{best1rm} <span style={{ fontSize: 10, color: C.dim }}>lbs</span></div>
                          <div style={{ fontFamily: "'DM Sans',sans-serif", fontSize: 9, color: C.dim }}>estimated max</div>
                        </div>
                      )}
                    </div>

                    <button onClick={e => { e.stopPropagation(); setModal(ex); }} style={{
                      display: "flex", alignItems: "center", gap: 10,
                      padding: "10px 18px", borderRadius: 2,
                      background: `linear-gradient(90deg, ${C.blue}cc, ${C.cyan}cc)`,
                      border: `1px solid ${C.lineHi}`,
                      color: C.bg, fontFamily: "'Barlow Condensed',sans-serif",
                      fontSize: 16, letterSpacing: 2, cursor: "pointer",
                      boxShadow: `0 0 20px ${C.cyanGlow}`,
                      transition: "all 0.2s",
                    }}>
                      <span style={{ fontSize: 14 }}>+</span> LOG SET
                    </button>
                  </div>
                )}
              </div>
            );
          })}
        </div>

        {/* ── SCHEDULE ── */}
        <div style={{ marginBottom: 28 }}>
          <div style={{ fontFamily: "'Barlow Condensed',sans-serif", fontSize: 11, letterSpacing: 5, color: C.cyanDim, marginBottom: 12, textTransform: "uppercase" }}>Suggested Schedule</div>
          <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 10 }}>
            {[
              { freq: "2× / week", plan: ["Mon — Workout A", "Thu — Workout B"] },
              { freq: "3× / week", plan: ["Mon — Workout A", "Wed — Workout B", "Fri — Workout A"] },
            ].map(s => (
              <div key={s.freq} style={{ background: C.bg1, border: `1px solid ${C.line}`, borderRadius: 2, padding: "14px 16px" }}>
                <div style={{ fontFamily: "'Barlow Condensed',sans-serif", fontSize: 18, color: C.cyan, letterSpacing: 2, marginBottom: 10 }}>{s.freq}</div>
                {s.plan.map(d => (
                  <div key={d} style={{ fontFamily: "'DM Sans',sans-serif", fontSize: 12, color: C.dimHi, lineHeight: 2, display: "flex", alignItems: "center", gap: 8 }}>
                    <div style={{ width: 4, height: 4, background: C.cyan, borderRadius: "50%", opacity: 0.5 }} />{d}
                  </div>
                ))}
              </div>
            ))}
          </div>
        </div>

        {/* ── TIPS ── */}
        <div style={{ background: C.bg1, border: `1px solid ${C.line}`, borderRadius: 2, padding: "18px 20px", marginBottom: 32, position: "relative", overflow: "hidden" }}>
          <div style={{ position: "absolute", top: 0, left: 0, right: 0, height: 2, background: `linear-gradient(90deg, ${C.blue}, ${C.cyan}, transparent)` }} />
          <div style={{ fontFamily: "'Barlow Condensed',sans-serif", fontSize: 11, letterSpacing: 5, color: C.cyanDim, marginBottom: 14, textTransform: "uppercase" }}>Protocol Notes</div>
          {[
            "Warm up 5–10 min before lifting — bike, jump rope, or dynamic movement.",
            "Progressive overload is the only rule that matters. Add weight or reps every session.",
            "End each session with a high-rep finisher (20+ reps) on cables for max pump.",
            "Hit 0.7–1g protein per lb of bodyweight. Sleep 7–9h. Everything else is secondary.",
          ].map((tip, i) => (
            <div key={i} style={{ display: "flex", gap: 12, marginBottom: i < 3 ? 10 : 0, alignItems: "flex-start" }}>
              <div style={{ fontFamily: "'Barlow Condensed',sans-serif", fontSize: 13, color: C.cyanDim, letterSpacing: 1, marginTop: 1, flexShrink: 0 }}>0{i + 1}</div>
              <div style={{ fontFamily: "'DM Sans',sans-serif", fontSize: 12, color: C.dimHi, lineHeight: 1.7 }}>{tip}</div>
            </div>
          ))}
        </div>

      </div>

      {modal && <LogModal exercise={modal} logs={logs[modal.name] || []} onClose={() => setModal(null)} onSave={saveLog} />}
      {dash && <Dashboard allLogs={logs} onClose={() => setDash(false)} />}
    </div>
  );
}
