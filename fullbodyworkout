// ── DASHBOARD ──────────────────────────────────────────────────────────────
function Dashboard({ allLogs, onClose }) {
  const all = [...workouts.A.exercises, ...workouts.B.exercises];
  const lifts = all.map(ex => {
    const logs = allLogs[ex.name] || [];
    if (!logs.length) return null;
    const best = Math.max(...logs.map(l => l.e1rm));
    const prog = logs[0].e1rm ? Math.round(((logs[logs.length-1].e1rm - logs[0].e1rm) / logs[0].e1rm) * 100) : null;
    return { ...ex, logs, best, prog, isPR: logs.length > 1 && logs[logs.length-1].e1rm === best };
  }).filter(Boolean);

  const keyLifts = lifts.filter(l => KEY_LIFTS.includes(l.name));
  const otherLifts = lifts.filter(l => !KEY_LIFTS.includes(l.name));
  const totalLogs = Object.values(allLogs).reduce((a, l) => a + l.length, 0);

  return (
    <div style={{ position: "fixed", inset: 0, background: C.bg, zIndex: 998, overflowY: "auto" }}>
      <style>{`
        @import url('https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@300;400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap');
        .dc { background: ${C.bg1}; border: 1px solid ${C.line}; border-radius: 2px; padding: 16px; position: relative; overflow: hidden; transition: border-color 0.2s; }
        .dc:hover { border-color: ${C.lineHi}; }
