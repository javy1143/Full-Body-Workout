const KEY_LIFTS = ["Barbell Bench Press","Barbell Back Squat","Bent-Over Barbell Row","Weighted Pull-Up","Romanian Deadlift"];

function calc1RM(w, r) { return (!w || !r) ? 0 : Math.round(w * (1 + r / 30)); }
function suggestNext(logs, repStr) {
  if (!logs?.length) return null;
  const last = logs[logs.length - 1];
  const top = parseInt((repStr || "10").split("–")[1]) || parseInt(repStr) || 10;
  const bump = last.reps >= top ? (last.weight > 80 ? 5 : 2.5) : 0;
  return Math.round((last.weight + bump) * 2) / 2;
}

async function storageGet(k) { try { const r = await window.storage.get(k); return r ? JSON.parse(r.value) : null; } catch { return null; } }
async function storageSet(k, v) { try { await window.storage.set(k, JSON.stringify(v)); } catch {} }

// ── SPARKLINE ──────────────────────────────────────────────────────────────
function Sparkline({ data, width = 80, height = 30 }) {
  if (!data?.length || data.length < 2)
    return <span style={{ fontFamily: "monospace", fontSize: 11, color: C.dim }}>—</span>;
  const vals = data.map(d => d.e1rm);
  const min = Math.min(...vals), max = Math.max(...vals), range = max - min || 1;
  const pts = vals.map((v, i) => {
    const x = (i / (vals.length - 1)) * width;
    const y = height - ((v - min) / range) * (height - 8) - 4;
    return `${x},${y}`;
  }).join(" ");
  const [lx, ly] = pts.split(" ").pop().split(",");
  return (
    <svg width={width} height={height} style={{ overflow: "visible" }}>
      <defs>
        <linearGradient id="spark" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" stopColor={C.blue} />
          <stop offset="100%" stopColor={C.cyan} />
        </linearGradient>
      </defs>
      <polyline points={pts} fill="none" stroke="url(#spark)" strokeWidth="1.8" strokeLinejoin="round" />
      <circle cx={lx} cy={ly} r="3" fill={C.cyan} style={{ filter: `drop-shadow(0 0 4px ${C.cyan})` }} />
    </svg>
  );
}

